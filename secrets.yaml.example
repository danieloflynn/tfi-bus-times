# TFI Display — API key (secrets)
# Copy to /etc/tfi-display/secrets.yaml and fill in your key.
# Get a free API key: https://developer.nationaltransport.ie/
#
# Set restrictive permissions so only root can read it:
#   sudo chown root:root /etc/tfi-display/secrets.yaml
#   sudo chmod 600 /etc/tfi-display/secrets.yaml
#
# This file is NEVER read or written by the updater.
# Alternatively, set the TFI_API_KEY environment variable.

api_key: "your-api-key-here"
