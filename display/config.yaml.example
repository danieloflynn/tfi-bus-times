# TFI Bus Display — example configuration
# Copy to config.yaml and fill in your API key.
# Get a free API key from https://developer.nationaltransport.ie/

api_key: ""

# -----------------------------------------------------------------------
# Bus stops to monitor.  stop_number is the number printed on the stop.
# label is shown in the display header.
# -----------------------------------------------------------------------
stops:
  - stop_number: "478"
    label: "Vinny's"
  - stop_number: "2808"
    label: "Sandymount"
  - stop_number: "999126"
    label: "Dart"

# -----------------------------------------------------------------------
# Optional: show only these route short names.  Leave empty to show all.
# -----------------------------------------------------------------------
routes:
  - "4"
  - "7"
  - "7A"
  - "S2"
  - "DART"

# -----------------------------------------------------------------------
# Realtime polling interval in seconds (default: 60).
# -----------------------------------------------------------------------
poll_interval_seconds: 60

# -----------------------------------------------------------------------
# How far ahead to show arrivals in minutes (default: 90).
# -----------------------------------------------------------------------
max_minutes: 90

# -----------------------------------------------------------------------
# Display hardware.  Supported: "2.13" (250×122) or "2.9" (296×128).
# -----------------------------------------------------------------------
display_model: "10.3"

# -----------------------------------------------------------------------
# Where to cache the parsed GTFS static data.
# -----------------------------------------------------------------------
data_dir: "/var/lib/tfi-display"

# -----------------------------------------------------------------------
# SPI and GPIO pin numbers (BCM).  These match the Waveshare HAT default.
# Usually you do not need to change these.
# -----------------------------------------------------------------------
spi_bus: 0
spi_chip: 0
pin_dc: 25
pin_rst: 17
pin_busy: 24
