# TFI Bus Display — example configuration
# Copy to /etc/tfi-display/config.yaml and edit to suit your setup.
#
# API key lives in a separate file: see secrets.yaml.example.
# Do NOT add api_key here — it will be ignored if secrets.yaml is present.

# -----------------------------------------------------------------------
# Bus stops to monitor.  stop_number is the number printed on the stop.
# label is shown in the display header.
# -----------------------------------------------------------------------
stops:
  - stop_number: "478"
    label: "Vinny's"
  - stop_number: "2808"
    label: "Sandymount"
  - stop_number: "999126"
    label: "Dart"

# -----------------------------------------------------------------------
# Optional: show only these route short names.  Leave empty to show all.
# -----------------------------------------------------------------------
routes:
  - "4"
  - "7"
  - "7A"
  - "S2"
  - "DART"

# -----------------------------------------------------------------------
# Realtime polling interval in seconds (default: 60).
# -----------------------------------------------------------------------
poll_interval_seconds: 60

# -----------------------------------------------------------------------
# Paging: flip through arrival pages every N seconds.
# max_pages: 0 = unlimited (cycle all available arrivals)
#            2 = only cycle between page 1 and page 2
# -----------------------------------------------------------------------
page_interval_seconds: 5
max_pages: 2

# -----------------------------------------------------------------------
# How far ahead to show arrivals in minutes (default: 90).
# -----------------------------------------------------------------------
max_minutes: 90

# -----------------------------------------------------------------------
# Display: 7" LCD HAT via /dev/fb0.
# framebuffer_device defaults to "/dev/fb0" — omit if that's your device.
# -----------------------------------------------------------------------
display_model: "lcd"
# framebuffer_device: "/dev/fb0"

# -----------------------------------------------------------------------
# Wake/sleep schedule (optional).  If set, the display is powered off
# outside the active window, saving backlight wear overnight.
# Both fields must be set together; omit both to run 24/7 (default).
# Format: HH:MM in 24-hour local time.
# Overnight ranges (stop < start) are supported, e.g. 22:00–06:00.
# -----------------------------------------------------------------------
# start_time: "07:00"
# stop_time: "22:00"
